# --- Required for Phase 1 ---
ANTHROPIC_API_KEY=sk-ant-...
SUPADATA_API_KEY=

# Vercel REST API token. Generate at https://vercel.com/account/tokens
VERCEL_TOKEN=
# Optional: team scope. Leave blank for personal account.
VERCEL_TEAM_ID=

# --- Phase 2 ---
# Stripe Secret Key. Without this, monetize() returns PREVIEW links
# (https://example.com/buy/...) so the pipeline still demos end-to-end.
# Get one at https://dashboard.stripe.com/apikeys — start with a test key (sk_test_*).
STRIPE_SECRET_KEY=

# --- Optional fallbacks ---
# Used only if Supadata is missing or fails.
YOUTUBE_API_KEY=

# Where ClonePilot writes scaffolded repos. Defaults to OS temp dir.
CLONEPILOT_WORKSPACE=

# Model overrides (defaults baked in)
CLONEPILOT_MODEL_BLUEPRINT=claude-sonnet-4-6
CLONEPILOT_MODEL_COPY=claude-sonnet-4-6
